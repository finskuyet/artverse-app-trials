# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SELLER_TOKEN: Token to access the Seller Portal (Portal Penjual).
# Default fallback is "admin" if not specified.
SELLER_TOKEN="admin"

# --- DATABASE CONFIGURATION FOR ENTERPRISE DEPLOYMENT ---
# Set DATABASE_MODE to "supabase" to enable PostgreSQL with Supabase.
# Set to "local" (or leave blank) to use local db.json file storage.
DATABASE_MODE="local"

# Supabase Credentials (obtain from your Supabase Project Settings -> API)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""

